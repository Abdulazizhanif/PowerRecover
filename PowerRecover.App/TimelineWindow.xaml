<Window x:Class="PowerRecover.App.TimelineWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Forensic Timeline"
        Width="1100" Height="650"
        MinWidth="800" MinHeight="400"
        WindowStartupLocation="CenterOwner"
        Background="#0A0D11"
        Foreground="#C8D0DC"
        FontFamily="Segoe UI">

    <Window.Resources>
        <!-- Column header style -->
        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background"   Value="#131820"/>
            <Setter Property="Foreground"   Value="#7A8A9A"/>
            <Setter Property="Padding"      Value="8,4"/>
            <Setter Property="FontSize"     Value="10"/>
            <Setter Property="FontWeight"   Value="SemiBold"/>
            <Setter Property="BorderBrush" Value="#1C2530"/>
            <Setter Property="BorderThickness" Value="0,0,1,1"/>
        </Style>
        <Style TargetType="DataGridCell">
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding"         Value="8,3"/>
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="Foreground"      Value="#C8D0DC"/>
            <Setter Property="FontFamily"      Value="JetBrains Mono, Consolas, monospace"/>
            <Setter Property="FontSize"        Value="11"/>
        </Style>
        <Style TargetType="DataGridRow">
            <Setter Property="Background" Value="Transparent"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#1A2535"/>
                </Trigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#141C28"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style TargetType="TextBox" x:Key="FilterBox">
            <Setter Property="Background"  Value="#0E1420"/>
            <Setter Property="Foreground"  Value="#C8D0DC"/>
            <Setter Property="BorderBrush" Value="#1C2530"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding"     Value="6,4"/>
            <Setter Property="FontSize"    Value="11"/>
            <Setter Property="CaretBrush" Value="#00E5CC"/>
        </Style>
        <Style TargetType="ComboBox" x:Key="FilterCombo">
            <Setter Property="Background"  Value="#0E1420"/>
            <Setter Property="Foreground"  Value="#C8D0DC"/>
            <Setter Property="BorderBrush" Value="#1C2530"/>
            <Setter Property="Padding"     Value="6,4"/>
            <Setter Property="FontSize"    Value="11"/>
        </Style>
        <Style TargetType="Button" x:Key="ToolBtn">
            <Setter Property="Background"  Value="#131820"/>
            <Setter Property="Foreground"  Value="#00E5CC"/>
            <Setter Property="BorderBrush" Value="#1C2530"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding"     Value="10,4"/>
            <Setter Property="FontSize"    Value="11"/>
            <Setter Property="Cursor"      Value="Hand"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- filter bar -->
            <RowDefinition Height="Auto"/>  <!-- stats bar  -->
            <RowDefinition Height="*"/>     <!-- grid       -->
        </Grid.RowDefinitions>

        <!-- ── Filter bar ── -->
        <Border Grid.Row="0" Background="#0E1420" BorderBrush="#1C2530"
                BorderThickness="0,0,0,1" Padding="12,8">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">

                <TextBlock Text="SEARCH" Foreground="#4A6080" FontSize="9"
                           FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,6,0"/>
                <TextBox x:Name="SearchBox" Width="240"
                         Style="{StaticResource FilterBox}"
                         TextChanged="OnSearchTextChanged"
                         ToolTip="Filter by filename or path"/>

                <TextBlock Text="KIND" Foreground="#4A6080" FontSize="9"
                           FontWeight="SemiBold" VerticalAlignment="Center" Margin="16,0,6,0"/>
                <ComboBox x:Name="KindFilter" Width="140"
                          Style="{StaticResource FilterCombo}"
                          SelectionChanged="OnKindFilterChanged">
                    <ComboBoxItem Content="All Events"   Tag="All"             IsSelected="True"/>
                    <ComboBoxItem Content="Created"      Tag="Created"/>
                    <ComboBoxItem Content="Modified"     Tag="Modified"/>
                    <ComboBoxItem Content="Accessed"     Tag="Accessed"/>
                    <ComboBoxItem Content="Deleted"      Tag="Deleted"/>
                    <ComboBoxItem Content="Renamed"      Tag="Renamed"/>
                    <ComboBoxItem Content="Overwritten"  Tag="Overwritten"/>
                    <ComboBoxItem Content="Truncated"    Tag="Truncated"/>
                    <ComboBoxItem Content="Metadata"     Tag="MetadataChanged"/>
                </ComboBox>

                <Button Content="✕ Clear" Style="{StaticResource ToolBtn}"
                        Margin="10,0,0,0" Click="OnClearFilter"/>

                <Button Content="⬇ Export CSV" Style="{StaticResource ToolBtn}"
                        Margin="16,0,0,0" Click="OnExportCsv"/>

            </StackPanel>
        </Border>

        <!-- ── Stats bar ── -->
        <Border Grid.Row="1" Background="#0A0D11" Padding="14,5">
            <TextBlock x:Name="StatsText" Foreground="#4A6080"
                       FontFamily="JetBrains Mono, Consolas, monospace"
                       FontSize="10"/>
        </Border>

        <!-- ── Timeline DataGrid ── -->
        <DataGrid x:Name="EventGrid"
                  Grid.Row="2"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  SelectionMode="Extended"
                  GridLinesVisibility="Horizontal"
                  HorizontalGridLinesBrush="#0F1720"
                  HeadersVisibility="Column"
                  Background="#0A0D11"
                  RowBackground="#0A0D11"
                  AlternatingRowBackground="#0C1018"
                  CanUserResizeRows="False"
                  CanUserSortColumns="True"
                  BorderThickness="0"
                  VirtualizingPanel.IsVirtualizing="True"
                  VirtualizingPanel.VirtualizationMode="Recycling"
                  EnableRowVirtualization="True">
            <DataGrid.Columns>

                <!-- Timestamp -->
                <DataGridTextColumn Header="TIMESTAMP (UTC)"
                                    Binding="{Binding Timestamp}"
                                    Width="155" SortMemberPath="Timestamp"/>

                <!-- Kind — color coded via DataGridTemplateColumn -->
                <DataGridTemplateColumn Header="KIND" Width="115" SortMemberPath="Kind">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Border CornerRadius="2" Padding="4,1" HorizontalAlignment="Left"
                                        Background="#1A2535">
                                    <TextBlock Text="{Binding Kind}"
                                            FontSize="10" FontWeight="SemiBold"
                                            Foreground="#00E5CC"/>
                                </Border>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                <!-- Source -->
                <DataGridTextColumn Header="SOURCE"
                                    Binding="{Binding Source}"
                                    Width="80"/>

                <!-- File name -->
                <DataGridTextColumn Header="FILENAME"
                                    Binding="{Binding FileName}"
                                    Width="200"/>

                <!-- Full path -->
                <DataGridTextColumn Header="PATH"
                                    Binding="{Binding FullPath}"
                                    Width="*"/>

                <!-- USN -->
                <DataGridTextColumn Header="USN"
                                    Binding="{Binding Usn}"
                                    Width="100"/>

            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Window>
